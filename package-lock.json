{
  "name": "sentinel-link",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "sentinel-link",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "engines": {
        "node": ">=20"
      }
    },
    "apps/external-helper": {
      "name": "@sentinel-link/helper",
      "version": "0.1.0",
      "dependencies": {
        "@sentinel-link/shared": "file:../../packages/shared"
      }
    },
    "apps/native-host": {
      "name": "@sentinel-link/native-host",
      "version": "0.1.0"
    },
    "node_modules/@sentinel-link/helper": {
      "resolved": "apps/external-helper",
      "link": true
    },
    "node_modules/@sentinel-link/native-host": {
      "resolved": "apps/native-host",
      "link": true
    },
    "node_modules/@sentinel-link/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "packages/shared": {
      "name": "@sentinel-link/shared",
      "version": "0.1.0"
    }
  }
}
