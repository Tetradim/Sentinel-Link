{
  "name": "extension-external",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "extension-external",
      "workspaces": [
        "apps/*",
        "packages/*"
      ],
      "engines": {
        "node": ">=20"
      }
    },
    "apps/external-helper": {
      "name": "@extension-external/helper",
      "version": "0.1.0",
      "dependencies": {
        "@extension-external/shared": "file:../../packages/shared"
      }
    },
    "node_modules/@extension-external/helper": {
      "resolved": "apps/external-helper",
      "link": true
    },
    "node_modules/@extension-external/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "packages/shared": {
      "name": "@extension-external/shared",
      "version": "0.1.0"
    }
  }
}
